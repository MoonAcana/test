# Supported values: mock, qwen, keypoint
AI_PROVIDER=keypoint

# Required only when AI_PROVIDER=qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-vl-plus

# If qwen-vl-plus is unavailable in your account, replace QWEN_MODEL with a
# video-capable model name supported by your Alibaba Cloud Model Studio console.
